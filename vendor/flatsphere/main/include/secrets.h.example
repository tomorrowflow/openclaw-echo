/*
 * secrets.h — Copy this to secrets.h and fill in your values.
 * NEVER commit secrets.h to version control.
 */

#pragma once

#define SECRETS_WIFI_SSID       "your_ssid"
#define SECRETS_WIFI_PASSWORD   "your_password"

/* OpenClaw gateway — use LAN IP or Tailscale hostname */
#define SECRETS_OPENCLAW_HOST   "192.168.1.100"
#define SECRETS_OPENCLAW_PORT   18789
#define SECRETS_OPENCLAW_TOKEN  "your_token"

/* ED25519 device key — 64-char hex string (32-byte seed).
 * Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
 * Leave empty to skip device auth (token-only). */
#define SECRETS_DEVICE_KEY_HEX  ""

/* STT server (faster-whisper) */
#define SECRETS_STT_HOST        "192.168.1.100"
#define SECRETS_STT_PORT        5051

/* TTS server (Kokoro) */
#define SECRETS_TTS_HOST        "192.168.1.100"
#define SECRETS_TTS_PORT        5050
#define SECRETS_TTS_VOICE       "alloy"
#define SECRETS_TTS_MODEL       "kokoro"

/* Tailscale auth key (get from https://login.tailscale.com/admin/settings/keys)
 * Leave empty to disable Tailscale. Use a reusable, ephemeral key. */
#define SECRETS_TAILSCALE_AUTH_KEY  ""
#define SECRETS_TAILSCALE_DEVICE   "openclaw-echo"
